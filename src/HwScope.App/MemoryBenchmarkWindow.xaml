<ui:FluentWindow x:Class="HwScope.App.MemoryBenchmarkWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="HwScope Cache &amp; Memory Benchmark"
                 Height="580"
                 Width="780"
                 MinHeight="540"
                 MinWidth="740"
                 Background="{DynamicResource HwScopePanelBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner">
    <ui:FluentWindow.Resources>
        <Style x:Key="BenchmarkCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HwScopeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="CellBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HwScopeIconBackplateBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Padding" Value="8,0" />
        </Style>
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource HwScopeMutedTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource HwScopeTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ColumnHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource HwScopeStrongTextBrush}" />
        </Style>
        <Style x:Key="RowHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource HwScopeStrongTextBrush}" />
        </Style>
        <Style x:Key="InfoRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style x:Key="InfoValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource HwScopeTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="InfoCardTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource HwScopeStrongTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource HwScopeContentBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title="Cache &amp; Memory Benchmark"
                     Icon="{ui:SymbolIcon Gauge32}" />

        <Grid Grid.Row="1" Margin="16,12,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Cache &amp; Memory Benchmark"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeTextBrush}" />
                <TextBlock x:Name="StatusText"
                           Margin="0,5,0,0"
                           Text="准备就绪"
                           FontSize="12"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Column="1"
                    Width="56"
                    Height="56"
                    Margin="16,0,0,0"
                    Background="{DynamicResource HwScopeIconBackplateBrush}"
                    BorderBrush="{DynamicResource HwScopeLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ui:SymbolIcon Symbol="Gauge32"
                               FontSize="28"
                               Foreground="{DynamicResource HwScopeIconBrush}" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="16,0,16,0"
                Background="Transparent"
                BorderThickness="0"
                Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource BenchmarkCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="1" Text="Read" Style="{StaticResource ColumnHeaderTextStyle}" />
                            <TextBlock Grid.Column="2" Text="Write" Style="{StaticResource ColumnHeaderTextStyle}" />
                            <TextBlock Grid.Column="3" Text="Copy" Style="{StaticResource ColumnHeaderTextStyle}" />
                            <TextBlock Grid.Column="4" Text="Latency" Style="{StaticResource ColumnHeaderTextStyle}" />

                            <TextBlock Grid.Row="1" Text="Memory" Style="{StaticResource RowHeaderTextStyle}" />
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="MemoryReadText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="MemoryWriteText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="MemoryCopyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="MemoryLatencyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>

                            <TextBlock Grid.Row="2" Text="L1 Cache" Style="{StaticResource LabelTextStyle}" />
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L1ReadText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L1WriteText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="2" Grid.Column="3" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L1CopyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L1LatencyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <TextBlock Grid.Row="3" Text="L2 Cache" Style="{StaticResource LabelTextStyle}" />
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L2ReadText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L2WriteText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="3" Grid.Column="3" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L2CopyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="3" Grid.Column="4" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L2LatencyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <TextBlock Grid.Row="4" Text="L3 Cache" Style="{StaticResource LabelTextStyle}" />
                            <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L3ReadText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L3WriteText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="4" Grid.Column="3" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L3CopyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                            <Border Grid.Row="4" Grid.Column="4" Style="{StaticResource CellBorderStyle}">
                                <TextBlock x:Name="L3LatencyText" Text="" Style="{StaticResource ValueTextStyle}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Margin="0,12,0,0" Style="{StaticResource BenchmarkCardStyle}">
                        <StackPanel>
                            <TextBlock Text="CPU" Style="{StaticResource InfoCardTitleTextStyle}" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU Type" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock x:Name="CpuTypeText" Grid.Column="1" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU Clock" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="2" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU FSB" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="3" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU Multiplier" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="4" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="North Bridge Clock" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Style="{StaticResource BenchmarkCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Memory" Style="{StaticResource InfoCardTitleTextStyle}" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Memory Bus" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Memory Type" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock x:Name="MemoryTypeText" Grid.Column="1" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="2" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Chipset" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="3" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Motherboard" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock x:Name="MotherboardText" Grid.Column="1" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="4" Style="{StaticResource InfoRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="BIOS Version" Style="{StaticResource LabelTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="" Style="{StaticResource InfoValueTextStyle}" Margin="8,0,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3"
              Margin="16,12,16,14"
              Background="{DynamicResource HwScopePanelBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       x:Name="DiagnosticsButton"
                       Width="110"
                       Height="32"
                       Icon="{ui:SymbolIcon DocumentBulletList24}"
                       Content="Diagnostics"
                       IsEnabled="False"
                       Click="DiagnosticsButton_Click" />
            <ui:Button Grid.Column="1"
                       x:Name="StartBenchmarkButton"
                       Width="180"
                       Height="32"
                       Icon="{ui:SymbolIcon Play24}"
                       Content="Start Benchmark"
                       HorizontalAlignment="Center"
                       Click="StartBenchmarkButton_Click" />
            <ui:Button Grid.Column="2"
                       Width="110"
                       Height="32"
                       Icon="{ui:SymbolIcon Dismiss24}"
                       Content="Close"
                       Click="CloseButton_Click" />
        </Grid>
    </Grid>
</ui:FluentWindow>
