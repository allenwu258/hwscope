<ui:FluentWindow x:Class="HwScope.App.MemoryBenchmarkWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="HwScope Cache &amp; Memory Benchmark"
                 Height="580"
                 Width="780"
                 MinHeight="540"
                 MinWidth="740"
                 Background="#FFFFFF"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 WindowStartupLocation="CenterOwner">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="BenchmarkLineBrush" Color="#808080" />
        <Style x:Key="CellBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BenchmarkLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#000000" />
        </Style>
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#000000" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title="Cache &amp; Memory Benchmark"
                     Icon="{ui:SymbolIcon Gauge32}" />

        <Border Grid.Row="1"
                Margin="12,4,12,0"
                BorderBrush="{StaticResource BenchmarkLineBrush}"
                BorderThickness="1">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="Read" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="Write" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="Copy" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="Latency" Style="{StaticResource LabelTextStyle}" HorizontalAlignment="Center" />

                <TextBlock Grid.Row="1" Text="Memory" Style="{StaticResource LabelTextStyle}" />
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CellBorderStyle}">
                    <TextBlock x:Name="MemoryReadText" Text="" Style="{StaticResource ValueTextStyle}" />
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CellBorderStyle}">
                    <TextBlock x:Name="MemoryWriteText" Text="" Style="{StaticResource ValueTextStyle}" />
                </Border>
                <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource CellBorderStyle}">
                    <TextBlock x:Name="MemoryCopyText" Text="" Style="{StaticResource ValueTextStyle}" />
                </Border>
                <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource CellBorderStyle}">
                    <TextBlock x:Name="MemoryLatencyText" Text="" Style="{StaticResource ValueTextStyle}" />
                </Border>

                <TextBlock Grid.Row="2" Text="L1 Cache" Style="{StaticResource LabelTextStyle}" />
                <TextBlock Grid.Row="3" Text="L2 Cache" Style="{StaticResource LabelTextStyle}" />
                <TextBlock Grid.Row="4" Text="L3 Cache" Style="{StaticResource LabelTextStyle}" />

                <Grid Grid.Row="6" Grid.ColumnSpan="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CPU Type" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock x:Name="CpuTypeText" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="1" Text="CPU Clock" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="2" Text="CPU FSB" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="3" Text="CPU Multiplier" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="4" Text="North Bridge Clock" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                </Grid>

                <Grid Grid.Row="8" Grid.ColumnSpan="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Memory Bus" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="1" Text="Memory Type" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock x:Name="MemoryTypeText" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="2" Text="Chipset" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="3" Text="Motherboard" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock x:Name="MotherboardText" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                    <TextBlock Grid.Row="4" Text="BIOS Version" Style="{StaticResource LabelTextStyle}" />
                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource CellBorderStyle}" Margin="4,0,4,0">
                        <TextBlock Text="" Style="{StaticResource LabelTextStyle}" Margin="8,0" />
                    </Border>
                </Grid>

                <TextBlock Grid.Row="9"
                           Grid.ColumnSpan="5"
                           x:Name="StatusText"
                           Text="准备就绪"
                           VerticalAlignment="Bottom"
                           Foreground="#000000" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Width="110"
                       Height="32"
                       Icon="{ui:SymbolIcon Save24}"
                       Content="Save"
                       IsEnabled="False" />
            <ui:Button Grid.Column="1"
                       x:Name="StartBenchmarkButton"
                       Width="180"
                       Height="32"
                       Icon="{ui:SymbolIcon Play24}"
                       Content="Start Benchmark"
                       HorizontalAlignment="Center"
                       Click="StartBenchmarkButton_Click" />
            <ui:Button Grid.Column="2"
                       Width="110"
                       Height="32"
                       Icon="{ui:SymbolIcon Dismiss24}"
                       Content="Close"
                       Click="CloseButton_Click" />
        </Grid>
    </Grid>
</ui:FluentWindow>
