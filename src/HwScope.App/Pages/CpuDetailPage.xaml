<UserControl x:Class="HwScope.App.Pages.CpuDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:HwScope.App.Pages"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="960">
    <UserControl.Resources>
        <Style x:Key="CpuSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HwScopeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="CpuSourceBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="{DynamicResource HwScopeIconBackplateBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HwScopeContentBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="CPU 详情"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeTextBrush}" />
                <TextBlock x:Name="CpuSubtitleText"
                           Margin="0,5,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                           Text="正在读取 CPU 信息..." />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ui:Button x:Name="RefreshButton"
                           Height="32"
                           MinWidth="78"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Content="刷新"
                           Click="RefreshButton_Click" />
                <ui:Button x:Name="CopyButton"
                           Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Copy24}"
                           Content="复制"
                           Click="CopyButton_Click" />
                <ui:Button x:Name="SaveButton"
                           Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Save24}"
                           Content="保存"
                           Click="SaveButton_Click" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="16,0,4,14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <Border Style="{StaticResource CpuSectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="ProcessorNameText"
                                       Text="读取中..."
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource HwScopeTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ProcessorMetaText"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                       Text="等待采集结果"
                                       TextWrapping="Wrap" />

                            <ItemsControl x:Name="HeaderChipsList" Margin="0,12,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="8,4"
                                                Background="{DynamicResource HwScopeIconBackplateBrush}"
                                                CornerRadius="6">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="74"
                                Height="74"
                                Margin="18,0,0,0"
                                VerticalAlignment="Top"
                                Background="{DynamicResource HwScopeIconBackplateBrush}"
                                CornerRadius="8">
                            <ui:SymbolIcon Symbol="DeveloperBoard20"
                                           FontSize="34"
                                           Foreground="{DynamicResource HwScopeIconBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <ItemsControl x:Name="SectionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:CpuSectionView}">
                            <Border Width="440"
                                    MinHeight="190"
                                    Style="{StaticResource CpuSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                    <ItemsControl ItemsSource="{Binding Rows}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:CpuFieldRowView}">
                                                <Border BorderBrush="{DynamicResource HwScopeLineBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        MinHeight="30">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="138" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource CpuSourceBadgeStyle}"
                                                                Margin="8,4,0,4"
                                                                ToolTip="{Binding SourceDescription}">
                                                            <TextBlock Text="{Binding Source}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource CpuSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="指令集"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="FeatureList" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:CpuFeatureView}">
                                    <Border Margin="0,0,6,6"
                                            Padding="8,4"
                                            Background="{DynamicResource HwScopeIconBackplateBrush}"
                                            BorderBrush="{DynamicResource HwScopeLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource HwScopeTextBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border x:Name="NotesPanel"
                        Style="{StaticResource CpuSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="数据说明"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="NotesList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,0,0,5"
                                               FontSize="13"
                                               Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
