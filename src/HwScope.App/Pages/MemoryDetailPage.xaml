<UserControl x:Class="HwScope.App.Pages.MemoryDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:HwScope.App.Pages"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="640"
             d:DesignWidth="980">
    <UserControl.Resources>
        <Style x:Key="MemorySectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HwScopeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="MemorySourceBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="{DynamicResource HwScopeIconBackplateBrush}" />
        </Style>

        <Style x:Key="MemoryModuleTileButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="290" />
            <Setter Property="MinHeight" Value="96" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{DynamicResource HwScopeCardBrush}"
                                BorderBrush="{DynamicResource HwScopeLineBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HwScopeIconBackplateBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HwScopeActiveViewBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HwScopeMutedTextBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HwScopeContentBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="内存 / SPD"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeTextBrush}" />
                <TextBlock x:Name="MemorySubtitleText"
                           Margin="0,5,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                           Text="正在读取内存信息..."
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ui:Button x:Name="RefreshButton"
                           Height="32"
                           MinWidth="78"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Content="刷新"
                           Click="RefreshButton_Click" />
                <ui:Button x:Name="CopyButton"
                           Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Copy24}"
                           Content="复制"
                           Click="CopyButton_Click" />
                <ui:Button x:Name="SaveButton"
                           Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Save24}"
                           Content="保存"
                           Click="SaveButton_Click" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="16,0,4,14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <Border Style="{StaticResource MemorySectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="MemorySummaryTitleText"
                                       Text="读取中..."
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource HwScopeTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="MemorySummaryMetaText"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                       Text="等待采集结果"
                                       TextWrapping="Wrap" />

                            <ItemsControl x:Name="SummaryChipsList" Margin="0,12,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="8,4"
                                                Background="{DynamicResource HwScopeIconBackplateBrush}"
                                                CornerRadius="6">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="74"
                                Height="74"
                                Margin="18,0,0,0"
                                VerticalAlignment="Top"
                                Background="{DynamicResource HwScopeIconBackplateBrush}"
                                CornerRadius="8">
                            <ui:SymbolIcon Symbol="Database24"
                                           FontSize="34"
                                           Foreground="{DynamicResource HwScopeIconBrush}" />
                        </Border>
                    </Grid>
                </Border>

                <ItemsControl x:Name="RuntimeSectionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:MemorySectionView}">
                            <Border Width="440"
                                    MinHeight="160"
                                    Style="{StaticResource MemorySectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                    <ItemsControl ItemsSource="{Binding Rows}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:MemoryFieldRowView}">
                                                <Border BorderBrush="{DynamicResource HwScopeLineBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        MinHeight="30">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="138" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource MemorySourceBadgeStyle}"
                                                                Margin="8,4,0,4"
                                                                ToolTip="{Binding SourceDescription}">
                                                            <TextBlock Text="{Binding Source}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource MemorySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="模块选择"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="ModuleTilesList" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:MemoryModuleTileView}">
                                    <Button Style="{StaticResource MemoryModuleTileButtonStyle}"
                                            Click="ModuleTile_Click">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource HwScopeStrongTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1"
                                                        Padding="6,2"
                                                        Background="{DynamicResource HwScopeIconBackplateBrush}"
                                                        CornerRadius="4"
                                                        Visibility="{Binding WarningVisibility}"
                                                        ToolTip="{Binding Warning}">
                                                    <TextBlock Text="注意"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Subtitle}"
                                                       Margin="0,6,0,0"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource HwScopeTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Detail}"
                                                       Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="ModuleSectionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:MemorySectionView}">
                            <Border Width="440"
                                    MinHeight="190"
                                    Style="{StaticResource MemorySectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                    <ItemsControl ItemsSource="{Binding Rows}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:MemoryFieldRowView}">
                                                <Border BorderBrush="{DynamicResource HwScopeLineBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        MinHeight="30">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="138" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Label}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource MemorySourceBadgeStyle}"
                                                                Margin="8,4,0,4"
                                                                ToolTip="{Binding SourceDescription}">
                                                            <TextBlock Text="{Binding Source}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource MemorySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Timing Profiles"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TimingProfilesList" Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:MemoryTimingProfileView}">
                                        <Border BorderBrush="{DynamicResource HwScopeLineBrush}"
                                                BorderThickness="0,0,0,1"
                                                MinHeight="34">
                                            <Grid MinWidth="760">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="100" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource HwScopeStrongTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Frequency}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="{Binding EffectiveRate}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="{Binding CasLatency}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="{Binding Trcd}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="{Binding Trp}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="6" Text="{Binding Tras}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="7" Text="{Binding Trc}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="8" Text="{Binding Voltage}" Foreground="{DynamicResource HwScopeTextBrush}" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border x:Name="NotesPanel"
                        Style="{StaticResource MemorySectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="数据说明"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="NotesList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,0,0,5"
                                               FontSize="13"
                                               Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
