<UserControl x:Class="HwScope.App.Pages.HardwareSummaryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:HwScope.App.Pages"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="840">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HwScopeLineBrush" Color="#E5E5E5" />
        <SolidColorBrush x:Key="HwScopeMutedTextBrush" Color="#666666" />
        <Style x:Key="HardwareRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="硬件概览"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="GeneratedAtText"
                           Margin="0,5,0,0"
                           FontSize="13"
                           Foreground="{StaticResource HwScopeMutedTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ui:Button x:Name="RefreshButton"
                           Width="88"
                           Height="34"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Content="刷新"
                           Click="RefreshButton_Click" />
                <ui:Button x:Name="CopyButton"
                           Width="88"
                           Height="34"
                           Margin="8,0,0,0"
                           Icon="{ui:SymbolIcon Copy24}"
                           Content="复制"
                           Click="CopyButton_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="#FFFFFFFF"
                BorderBrush="{StaticResource HwScopeLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18,4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="HardwareSummaryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:HardwareSummaryItem}">
                            <Border Style="{StaticResource HardwareRowStyle}">
                                <Grid MinHeight="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="116" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Label}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="#4B5563" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
