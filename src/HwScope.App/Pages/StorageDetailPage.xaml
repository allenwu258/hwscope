<UserControl x:Class="HwScope.App.Pages.StorageDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:HwScope.App.Pages"
             xmlns:storage="clr-namespace:HwScope.Core.Hardware.Storage;assembly=HwScope.Core"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1040">
    <UserControl.Resources>
        <Style x:Key="StorageSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource HwScopeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="StorageSourceBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="{DynamicResource HwScopeIconBackplateBrush}" />
        </Style>

        <Style x:Key="StorageDeviceTileButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="240" />
            <Setter Property="MinHeight" Value="88" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Padding="12"
                                Background="{DynamicResource HwScopeCardBrush}"
                                BorderBrush="{DynamicResource HwScopeLineBrush}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HwScopeIconBackplateBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HwScopeActiveViewBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HwScopeStatusInfoBrush}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StorageTileStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusUnknownBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static storage:StorageHealthStatus.Good}">
                    <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusGoodBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static storage:StorageHealthStatus.Caution}">
                    <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusCautionBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static storage:StorageHealthStatus.Critical}">
                    <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusCriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StorageAttributeRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static storage:StorageAttributeSeverity.Caution}">
                    <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusCautionBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static storage:StorageAttributeSeverity.Critical}">
                    <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusCriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HwScopeContentBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,14,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="存储设备"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeTextBrush}" />
                <TextBlock x:Name="StorageSubtitleText"
                           Margin="0,5,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                           Text="正在读取物理存储设备..."
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button x:Name="RefreshButton"
                           Height="32"
                           MinWidth="78"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Content="刷新"
                           Click="RefreshButton_Click" />
                <ui:Button x:Name="CopyButton"
                           Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Copy24}"
                           Content="复制"
                           Click="CopyButton_Click" />
                <ui:Button x:Name="SaveButton"
                           Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Save24}"
                           Content="保存"
                           Click="SaveButton_Click" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="16,0,4,14" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <Border Style="{StaticResource StorageSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="物理设备"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="DeviceTilesList" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:StorageDeviceTileView}">
                                    <Button Style="{StaticResource StorageDeviceTileButtonStyle}"
                                            Click="DeviceTile_Click">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Temperature}"
                                                           Margin="8,0,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource HwScopeTextBrush}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Model}"
                                                       Margin="0,5,0,0"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource HwScopeTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Style="{StaticResource StorageTileStatusTextStyle}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Volumes}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                            </Grid>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoDevicesText"
                                   Text="Windows 没有返回物理存储设备。"
                                   Margin="0,10,0,0"
                                   Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border x:Name="SelectedDevicePanel" Style="{StaticResource StorageSectionBorderStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="SelectedDeviceTitleText"
                                           Text="选择一个物理设备"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource HwScopeTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedDeviceMetaText"
                                           Margin="0,5,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Width="68"
                                    Height="68"
                                    Margin="16,0,0,0"
                                    Background="{DynamicResource HwScopeIconBackplateBrush}"
                                    CornerRadius="8">
                                <ui:SymbolIcon Symbol="HardDrive20"
                                               FontSize="32"
                                               Foreground="{DynamicResource HwScopeIconBrush}" />
                            </Border>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="健康状态" FontSize="12" Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                <TextBlock x:Name="HealthStatusText"
                                           Margin="0,4,0,0"
                                           Text="未知"
                                           FontSize="22"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="HealthReasonText"
                                           Margin="0,4,10,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="温度" FontSize="12" Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                <TextBlock x:Name="TemperatureText"
                                           Margin="0,4,0,0"
                                           Text="未报告"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource HwScopeTextBrush}" />
                                <TextBlock x:Name="RemainingLifeText"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                            </StackPanel>

                            <ItemsControl x:Name="HeaderChipsList" Grid.Column="2">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="8,4"
                                                Background="{DynamicResource HwScopeIconBackplateBrush}"
                                                CornerRadius="6">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="SectionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:StorageSectionView}">
                            <Border Width="440" MinHeight="176" Style="{StaticResource StorageSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                                    <ItemsControl ItemsSource="{Binding Rows}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:StorageFieldRowView}">
                                                <Border MinHeight="30"
                                                        BorderBrush="{DynamicResource HwScopeLineBrush}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="132" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource HwScopeTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <Border Grid.Column="2"
                                                                Margin="8,4,0,4"
                                                                Style="{StaticResource StorageSourceBadgeStyle}"
                                                                ToolTip="{Binding SourceDescription}">
                                                            <TextBlock Text="{Binding Source}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource StorageSectionBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SMART / Health 属性"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button x:Name="AllAttributesButton" Height="28" MinWidth="56" Content="全部" Click="AllAttributesButton_Click" />
                                <ui:Button x:Name="WarningAttributesButton" Height="28" MinWidth="56" Margin="4,0,0,0" Content="异常" Click="WarningAttributesButton_Click" />
                                <ui:Button x:Name="CriticalAttributesButton" Height="28" MinWidth="56" Margin="4,0,0,0" Content="关键" Click="CriticalAttributesButton_Click" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <DataGrid x:Name="AttributeGrid"
                                      MinHeight="280"
                                      MaxHeight="520"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      RowStyle="{StaticResource StorageAttributeRowStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="{DynamicResource HwScopeTextBrush}"
                                      HorizontalGridLinesBrush="{DynamicResource HwScopeLineBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="58" />
                                    <DataGridTextColumn Header="属性" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="解码值" Binding="{Binding DisplayValue}" Width="*" />
                                    <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="72" />
                                    <DataGridTextColumn x:Name="CurrentAttributeColumn" Header="当前" Binding="{Binding Current}" Width="66" Visibility="Collapsed" />
                                    <DataGridTextColumn x:Name="WorstAttributeColumn" Header="最差" Binding="{Binding Worst}" Width="66" Visibility="Collapsed" />
                                    <DataGridTextColumn x:Name="ThresholdAttributeColumn" Header="阈值" Binding="{Binding Threshold}" Width="66" Visibility="Collapsed" />
                                    <DataGridTextColumn Header="原始值" Binding="{Binding RawValue}" Width="280">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock x:Name="NoAttributesText"
                                       Text="当前设备身份可用，但未返回原生 SMART / Health 属性。"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StorageSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="卷与分区"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="VolumeList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:StorageVolumeRowView}">
                                    <Border MinHeight="44"
                                            BorderBrush="{DynamicResource HwScopeLineBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="150" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding Detail}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="{Binding Capacity}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{Binding Free}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoVolumesText"
                                   Text="未识别到关联卷；设备可能未分区、未挂载或由存储池管理。"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border x:Name="NotesPanel" Style="{StaticResource StorageSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="数据说明"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                        <ItemsControl x:Name="NotesList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Margin="0,0,0,5"
                                               FontSize="13"
                                               Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
