<ui:FluentWindow x:Class="HwScope.App.Windows.UsbTopologyDiagnosticsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="USB 精确诊断"
                 Width="1220"
                 Height="780"
                 MinWidth="1020"
                 MinHeight="660"
                 Background="{DynamicResource HwScopePanelBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner"
                 PreviewKeyDown="DiagnosticsWindow_PreviewKeyDown">
    <ui:FluentWindow.Resources>
        <DataTemplate x:Key="UsbDiagnosticFieldTemplate">
            <Border MinHeight="38"
                    BorderBrush="{DynamicResource HwScopeLineBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="155" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Label}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                    <TextBlock Grid.Column="1"
                               Margin="8,0"
                               Text="{Binding Value}"
                               ToolTip="{Binding Note}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource HwScopeTextBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Width="26"
                            Height="26"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="复制此字段"
                            AutomationProperties.Name="复制此字段"
                            Click="CopyFieldButton_Click">
                        <ui:SymbolIcon Width="16" Height="16" Symbol="Copy24" />
                    </Button>
                    <TextBlock Grid.Column="3"
                               Text="{Binding Source}"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource HwScopeStatusInfoBrush}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="UsbDiagnosticTreeItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource HwScopePanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title="USB 精确诊断"
                     Icon="{ui:SymbolIcon Search32}" />

        <Grid Grid.Row="1" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="USB 物理端口与描述符精确目录"
                           FontSize="19"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                <TextBlock x:Name="SummaryText"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}"
                           Text="正在加载 USB snapshot..." />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Height="32"
                           MinWidth="78"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Content="刷新"
                           Click="RefreshButton_Click" />
                <ui:Button Height="32"
                           MinWidth="92"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Content="刷新描述符"
                           ToolTip="重新读取当前物理设备的深层描述符"
                           Click="RefreshDescriptorButton_Click" />
                <ui:Button Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Copy24}"
                           Content="复制节点"
                           Click="CopyNodeButton_Click" />
                <ui:Button Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Save24}"
                           Content="保存节点"
                           Click="SaveNodeButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="16,0,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="搜索"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     Margin="8,0,14,0"
                     Padding="8,3"
                     VerticalContentAlignment="Center"
                     AutomationProperties.Name="搜索 USB 节点或已加载描述符"
                     TextChanged="SearchTextBox_TextChanged" />
            <TextBlock Grid.Column="2"
                       Text="筛选"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
            <ComboBox x:Name="FilterComboBox"
                      Grid.Column="3"
                      Height="30"
                      Margin="8,0,14,0"
                      SelectedIndex="0"
                      SelectionChanged="FilterComboBox_SelectionChanged">
                <ComboBoxItem Content="全部条目" Tag="All" />
                <ComboBoxItem Content="存在问题" Tag="Problems" />
                <ComboBoxItem Content="已连接" Tag="Connected" />
                <ComboBoxItem Content="空端口" Tag="EmptyPorts" />
                <ComboBoxItem Content="Controller / Hub" Tag="ControllersAndHubs" />
                <ComboBoxItem Content="物理设备" Tag="Devices" />
                <ComboBoxItem Content="已加载 Descriptor" Tag="Descriptors" />
            </ComboBox>
            <ui:Button Grid.Column="4"
                       MinWidth="72"
                       Height="30"
                       Margin="0,0,6,0"
                       Padding="8,0"
                       Icon="{ui:SymbolIcon ArrowExpandAll20}"
                       Content="展开"
                       ToolTip="全部展开"
                       Click="ExpandAllButton_Click" />
            <ui:Button Grid.Column="5"
                       MinWidth="72"
                       Height="30"
                       Padding="8,0"
                       Icon="{ui:SymbolIcon ArrowCollapseAll20}"
                       Content="折叠"
                       ToolTip="全部折叠"
                       Click="CollapseAllButton_Click" />
            <TextBlock x:Name="VisibleCountText"
                       Grid.Column="7"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
        </Grid>

        <Grid Grid.Row="3" Margin="16,0,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" MinWidth="300" MaxWidth="560" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="570" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource HwScopeCardBrush}"
                    BorderBrush="{DynamicResource HwScopeLineBrush}"
                    BorderThickness="1"
                    CornerRadius="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="12,0"
                               Text="精确目录树"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                    <ListBox x:Name="TreeRowsList"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding}"
                             ItemContainerStyle="{StaticResource UsbDiagnosticTreeItemStyle}"
                             SelectionChanged="TreeRowsList_SelectionChanged"
                             PreviewKeyDown="TreeRowsList_PreviewKeyDown"
                             AutomationProperties.Name="USB 物理端口与描述符精确目录树"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="48"
                                      Margin="{Binding Indent}"
                                      AutomationProperties.Name="{Binding Label}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Width="24"
                                            Height="24"
                                            Padding="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Content="{Binding ExpansionGlyph}"
                                            IsEnabled="{Binding HasChildren}"
                                            Tag="{Binding RowId}"
                                            ToolTip="展开或折叠"
                                            Click="TreeExpansionButton_Click" />
                                    <ui:SymbolIcon Grid.Column="1"
                                                   Width="20"
                                                   Height="20"
                                                   VerticalAlignment="Center"
                                                   Symbol="{Binding Icon}"
                                                   Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                    <Grid Grid.Column="2" Margin="4,4,8,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource HwScopeTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Grid Grid.Row="1" Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Coordinate}"
                                                       ToolTip="{Binding Coordinate}"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="{Binding KindLabel}"
                                                       ToolTip="{Binding KindLabel}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource HwScopeStatusInfoBrush}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="8,0,0,0"
                                                       Text="{Binding StatusText}"
                                                       ToolTip="{Binding StatusText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusGoodBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProblem}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource HwScopeStatusCriticalBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Padding="0,0,0,10"
                        BorderBrush="{DynamicResource HwScopeLineBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock x:Name="SelectedNodeTitleText"
                                   Text="请选择一个 USB 节点"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource HwScopeStrongTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SelectedNodeMetaText"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource HwScopeMutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TabControl x:Name="DetailsTabControl" Grid.Row="1" Margin="0,10,0,0">
                    <TabItem Header="总览">
                        <ScrollViewer x:Name="OverviewScrollViewer" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="OverviewFieldsList" ItemTemplate="{StaticResource UsbDiagnosticFieldTemplate}" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="连接与端口">
                        <ScrollViewer x:Name="ConnectionScrollViewer" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ConnectionFieldsList" ItemTemplate="{StaticResource UsbDiagnosticFieldTemplate}" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Descriptor">
                        <ScrollViewer x:Name="DescriptorScrollViewer" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="DescriptorFieldsList" ItemTemplate="{StaticResource UsbDiagnosticFieldTemplate}" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="PnP 与驱动">
                        <ScrollViewer x:Name="PnpScrollViewer" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="PnpFieldsList" ItemTemplate="{StaticResource UsbDiagnosticFieldTemplate}" />
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="原始">
                        <TextBox x:Name="RawReportTextBox"
                                 Margin="0"
                                 Padding="10"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="12"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="4"
                Padding="16,8"
                BorderBrush="{DynamicResource HwScopeLineBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       Foreground="{DynamicResource HwScopeMutedTextBrush}"
                       Text="等待 USB snapshot..."
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</ui:FluentWindow>
