<ui:FluentWindow x:Class="HwScope.App.Windows.CpuTopologyInspectWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="CPU Topology Inspect"
                 Height="720"
                 Width="1040"
                 MinHeight="560"
                 MinWidth="820"
                 Background="{DynamicResource HwScopePanelBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource HwScopePanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title="CPU Topology Inspect"
                     Icon="{ui:SymbolIcon Search32}" />

        <Grid Grid.Row="1" Margin="16,12,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="CpuNameText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeTextBrush}"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="GeneratedAtText"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <ui:Button Height="32"
                           MinWidth="78"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Copy24}"
                           Content="复制"
                           Click="CopyButton_Click" />
                <ui:Button Height="32"
                           MinWidth="78"
                           Margin="6,0,0,0"
                           Padding="10,0"
                           Icon="{ui:SymbolIcon Save24}"
                           Content="保存"
                           Click="SaveButton_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Margin="16,0,16,12"
                Padding="0"
                Background="{DynamicResource HwScopeCardBrush}"
                BorderBrush="{DynamicResource HwScopeLineBrush}"
                BorderThickness="1"
                CornerRadius="7">
            <TextBox x:Name="ReportTextBox"
                     Margin="1"
                     Padding="12"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     Background="Transparent"
                     BorderThickness="0"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="13"
                     Foreground="{DynamicResource HwScopeTextBrush}"
                     HorizontalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Margin="16,0,16,12"
                   FontSize="12"
                   Foreground="{DynamicResource HwScopeMutedTextBrush}" />
    </Grid>
</ui:FluentWindow>
