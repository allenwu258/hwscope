<ui:FluentWindow x:Class="HwScope.App.Windows.HardwarePreloadWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="HwScope"
                 Width="560"
                 Height="330"
                 MinWidth="560"
                 MinHeight="330"
                 MaxWidth="560"
                 MaxHeight="330"
                 ResizeMode="NoResize"
                 Background="{DynamicResource HwScopePanelBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 Icon="../Assets/HwScope.ico">
    <Grid Background="{DynamicResource HwScopeContentBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title=""
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="28,18,28,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="64"
                        Height="64"
                        Background="{DynamicResource HwScopeIconBackplateBrush}"
                        BorderBrush="{DynamicResource HwScopeLineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <ui:SymbolIcon Symbol="DeveloperBoard20"
                                   FontSize="34"
                                   Foreground="{DynamicResource HwScopeIconBrush}" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="18,2,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="HwScope"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HwScopeStrongTextBrush}" />
                    <TextBlock Text="正在建立硬件信息库"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,24,0,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText"
                           Text="正在预加载硬件信息..."
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HwScopeTextBrush}"
                           TextTrimming="CharacterEllipsis" />

                <ProgressBar x:Name="ProgressBar"
                             Grid.Row="1"
                             Height="6"
                             Margin="0,14,0,0"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="True" />

                <DockPanel Grid.Row="2" Margin="0,10,0,0">
                    <TextBlock x:Name="StepText"
                               DockPanel.Dock="Left"
                               Text="CPU · Memory · Topology · Devices"
                               FontSize="12"
                               Foreground="{DynamicResource HwScopeMutedTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="PercentText"
                               HorizontalAlignment="Right"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                </DockPanel>

                <TextBlock x:Name="FailureText"
                           Grid.Row="3"
                           Margin="0,16,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}" />
            </Grid>

            <Grid Grid.Row="2">
                <TextBlock x:Name="VersionText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource HwScopeMutedTextBrush}" />
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <ui:Button x:Name="RetryButton"
                               Content="重试"
                               Width="82"
                               Margin="0,0,8,0"
                               Visibility="Collapsed"
                               Click="RetryButton_Click" />
                    <ui:Button x:Name="ContinueButton"
                               Content="继续"
                               Width="82"
                               Visibility="Collapsed"
                               Click="ContinueButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
