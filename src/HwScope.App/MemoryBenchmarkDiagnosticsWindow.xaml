<ui:FluentWindow x:Class="HwScope.App.MemoryBenchmarkDiagnosticsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Memory Benchmark Diagnostics"
                 Height="620"
                 Width="780"
                 MinHeight="460"
                 MinWidth="620"
                 Background="{DynamicResource HwScopePanelBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource HwScopeContentBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title="Memory Benchmark Diagnostics"
                     Icon="{ui:SymbolIcon DocumentBulletList24}" />

        <Border Grid.Row="1"
                Margin="16,12,16,0"
                Padding="12"
                Background="{DynamicResource HwScopeCardBrush}"
                BorderBrush="{DynamicResource HwScopeLineBrush}"
                BorderThickness="1"
                CornerRadius="7">
            <TextBox x:Name="DiagnosticsTextBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     Background="{DynamicResource HwScopeIconBackplateBrush}"
                     BorderBrush="{DynamicResource HwScopeLineBrush}"
                     Foreground="{DynamicResource HwScopeTextBrush}"
                     FontFamily="Consolas"
                     FontSize="12"
                     HorizontalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>

        <Grid Grid.Row="2"
              Margin="16,12,16,14"
              Background="{DynamicResource HwScopePanelBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Width="110"
                       Height="32"
                       Icon="{ui:SymbolIcon Copy24}"
                       Content="Copy"
                       Click="CopyButton_Click" />

            <ui:Button Grid.Column="2"
                       Width="110"
                       Height="32"
                       Icon="{ui:SymbolIcon Dismiss24}"
                       Content="Close"
                       Click="CloseButton_Click" />
        </Grid>
    </Grid>
</ui:FluentWindow>
