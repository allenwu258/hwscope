<ui:FluentWindow x:Class="HwScope.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="HwScope"
                 MinHeight="640"
                 MinWidth="980"
                 Height="760"
                 Width="1280"
                 Background="{DynamicResource HwScopePanelBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Height="44"
                     Title="">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Desktop20"
                                   Width="20"
                                   Height="20"
                                   Margin="0,0,10,0" />
                    <TextBlock Text="HwScope"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0"
                               FontSize="14" />
                    <Menu Background="Transparent"
                          BorderThickness="0"
                          Padding="0">
                        <MenuItem Header="文件(_F)" />
                        <MenuItem Header="查看(_V)">
                            <MenuItem Header="主题">
                                <MenuItem x:Name="FollowSystemThemeMenuItem"
                                          Header="跟随系统"
                                          IsCheckable="True"
                                          Click="FollowSystemThemeMenuItem_Click" />
                                <MenuItem x:Name="LightThemeMenuItem"
                                          Header="浅色"
                                          IsCheckable="True"
                                          IsChecked="True"
                                          Click="LightThemeMenuItem_Click" />
                                <MenuItem x:Name="DarkThemeMenuItem"
                                          Header="深色"
                                          IsCheckable="True"
                                          Click="DarkThemeMenuItem_Click" />
                            </MenuItem>
                            <MenuItem x:Name="MicaBackdropMenuItem"
                                      Header="Mica 背景"
                                      IsCheckable="True"
                                      IsChecked="True"
                                      Click="MicaBackdropMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="StatusBarMenuItem"
                                      Header="状态栏"
                                      IsCheckable="True"
                                      IsChecked="False"
                                      Click="StatusBarMenuItem_Click" />
                        </MenuItem>
                        <MenuItem Header="报告(_R)" />
                        <MenuItem Header="工具(_T)">
                            <MenuItem Header="内存跑分" Click="ShowMemoryBenchmark_Click" />
                        </MenuItem>
                        <MenuItem Header="帮助(_H)" />
                    </Menu>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Border Grid.Row="1"
                Background="{DynamicResource HwScopePanelBrush}"
                BorderBrush="{DynamicResource HwScopeLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Home24}"
                               Content="概要"
                               Click="ShowHardwareSummary_Click" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon DocumentData24}"
                               Content="报告"
                               IsEnabled="False" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Pulse24}"
                               Content="传感器"
                               IsEnabled="False" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon DesktopToolbox24}"
                               Content="内存"
                               Click="ShowHardwareSummary_Click" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon TopSpeed20}"
                               Content="跑分"
                               Click="ShowMemoryBenchmark_Click" />
                </StackPanel>

                <TextBox Width="236"
                         Height="34"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Text="查找"
                         Foreground="{DynamicResource HwScopeMutedTextBrush}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Background="{DynamicResource HwScopeContentBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView x:Name="RootNavigation"
                               Grid.Column="0"
                               PaneDisplayMode="Left"
                               IsPaneOpen="True"
                               OpenPaneLength="236"
                               CompactPaneLength="48"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="False"
                               IsPaneVisible="True"
                               SelectionChanged="RootNavigation_SelectionChanged">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem x:Name="SummaryNavigationItem"
                                           Content="硬件概览"
                                           Tag="summary"
                                           IsActive="True"
                                           Icon="{ui:SymbolIcon Home24}" />
                    <ui:NavigationViewItem Content="硬件"
                                           IsExpanded="True"
                                           Icon="{ui:SymbolIcon DeveloperBoard20}">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem Content="中央处理器 (CPU)"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon DeveloperBoard20}" />
                            <ui:NavigationViewItem Content="内存"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon Database24}" />
                            <ui:NavigationViewItem Content="显示设备"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon Desktop20}" />
                            <ui:NavigationViewItem Content="存储设备"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon HardDrive20}" />
                            <ui:NavigationViewItem Content="网络设备"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon WifiSettings20}" />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem Content="性能测试"
                                           IsExpanded="True"
                                           Icon="{ui:SymbolIcon TopSpeed20}">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem Content="内存跑分"
                                                   Tag="memory-benchmark"
                                                   Icon="{ui:SymbolIcon Gauge32}" />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>
            </ui:NavigationView>

            <ContentControl x:Name="PageHost"
                            Grid.Column="1"
                            Background="{DynamicResource HwScopeContentBrush}" />
        </Grid>

        <StatusBar x:Name="RootStatusBar"
                   Grid.Row="3"
                   Background="{DynamicResource HwScopePanelBrush}"
                   BorderBrush="{DynamicResource HwScopeLineBrush}"
                   BorderThickness="0,1,0,0"
                   Visibility="Collapsed">
            <StatusBarItem>
                <TextBlock x:Name="FooterStatusText" Text="准备就绪" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
