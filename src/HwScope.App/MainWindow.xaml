<Window x:Class="HwScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HwScope.App"
        mc:Ignorable="d"
        Title="HwScope"
        MinHeight="640"
        MinWidth="980"
        Height="720"
        Width="1120"
        Background="#ECEFF3"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="LineBrush" Color="#B8BEC7" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5F6875" />
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#F6F7F9" />
            <Setter Property="BorderBrush" Value="#C8CED7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="HardwareRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D8DDE5" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F7F7F7" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="文件(_F)" />
            <MenuItem Header="查看(_V)" />
            <MenuItem Header="报告(_R)" />
            <MenuItem Header="工具(_T)">
                <MenuItem Header="内存跑分" Click="ShowMemoryBenchmark_Click" />
            </MenuItem>
            <MenuItem Header="帮助(_H)" />
        </Menu>

        <Border DockPanel.Dock="Top" Background="#F1F2F4" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="10,8">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource ToolButtonStyle}" Click="ShowHardwareSummary_Click">
                        <StackPanel>
                            <TextBlock Text="▣" FontSize="24" HorizontalAlignment="Center" Foreground="#2D6E9F" />
                            <TextBlock Text="概要" HorizontalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" IsEnabled="False">
                        <StackPanel>
                            <TextBlock Text="▤" FontSize="24" HorizontalAlignment="Center" Foreground="#5C6670" />
                            <TextBlock Text="报告" HorizontalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" IsEnabled="False">
                        <StackPanel>
                            <TextBlock Text="♨" FontSize="24" HorizontalAlignment="Center" Foreground="#D74B34" />
                            <TextBlock Text="传感器" HorizontalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" Click="ShowMemoryBenchmark_Click">
                        <StackPanel>
                            <TextBlock Text="▥" FontSize="24" HorizontalAlignment="Center" Foreground="#2B8A3E" />
                            <TextBlock Text="内存" HorizontalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}" Click="ShowMemoryBenchmark_Click">
                        <StackPanel>
                            <TextBlock Text="◉" FontSize="24" HorizontalAlignment="Center" Foreground="#CC7A00" />
                            <TextBlock Text="跑分" HorizontalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBox DockPanel.Dock="Right" Width="180" Height="30" VerticalAlignment="Center" Text="查找" Foreground="#6B7280" />
            </DockPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#F7F7F7" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="FooterStatusText" Text="准备就绪" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
                <TreeView x:Name="NavigationTree"
                          BorderThickness="0"
                          FontSize="15"
                          SelectedItemChanged="NavigationTree_SelectedItemChanged">
                    <TreeViewItem Header="计算机" IsExpanded="True" Tag="summary">
                        <TreeViewItem Header="硬件概览" Tag="summary" />
                    </TreeViewItem>
                    <TreeViewItem Header="主板" IsExpanded="True">
                        <TreeViewItem Header="中央处理器 (CPU)" Tag="summary" />
                        <TreeViewItem Header="内存" Tag="summary" />
                    </TreeViewItem>
                    <TreeViewItem Header="显示设备" />
                    <TreeViewItem Header="存储设备" />
                    <TreeViewItem Header="网络设备" />
                    <TreeViewItem Header="性能测试" IsExpanded="True">
                        <TreeViewItem Header="内存跑分" Tag="memory-benchmark" />
                    </TreeViewItem>
                </TreeView>
            </Border>

            <Grid Grid.Column="1">
                <Grid x:Name="SummaryPage" Background="#FFFFFF">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="20,18,20,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="硬件概览" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock x:Name="GeneratedAtText" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button x:Name="RefreshButton" Width="76" Height="30" Content="刷新" Click="RefreshButton_Click" />
                            <Button x:Name="CopyButton" Width="76" Height="30" Margin="8,0,0,0" Content="复制" Click="CopyButton_Click" />
                        </StackPanel>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HardwareSummaryList" Margin="20,0,20,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:HardwareSummaryItem}">
                                    <Border Style="{StaticResource HardwareRowStyle}">
                                        <Grid MinHeight="46">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="108" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475467" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
