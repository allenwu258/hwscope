<ui:FluentWindow x:Class="HwScope.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:HwScope.App"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="HwScope"
                 MinHeight="640"
                 MinWidth="980"
                 Height="720"
                 Width="1120"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="HwScopePanelBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="HwScopeLineBrush" Color="#E5E5E5" />
        <SolidColorBrush x:Key="HwScopeMutedTextBrush" Color="#666666" />
        <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="HardwareRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource HwScopeLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="HwScope"
                     Icon="{ui:SymbolIcon Desktop20}" />

        <Menu Grid.Row="1"
              Background="Transparent"
              BorderBrush="{StaticResource HwScopeLineBrush}"
              BorderThickness="0,0,0,1">
            <MenuItem Header="文件(_F)" />
            <MenuItem Header="查看(_V)" />
            <MenuItem Header="报告(_R)" />
            <MenuItem Header="工具(_T)">
                <MenuItem Header="内存跑分" Click="ShowMemoryBenchmark_Click" />
            </MenuItem>
            <MenuItem Header="帮助(_H)" />
        </Menu>

        <Border Grid.Row="2"
                Background="{StaticResource HwScopePanelBrush}"
                BorderBrush="{StaticResource HwScopeLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Info24}"
                               Content="概要"
                               Click="ShowHardwareSummary_Click" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Document24}"
                               Content="报告"
                               IsEnabled="False" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Pulse24}"
                               Content="传感器"
                               IsEnabled="False" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Database24}"
                               Content="内存"
                               Click="ShowMemoryBenchmark_Click" />
                    <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                               Icon="{ui:SymbolIcon Trophy24}"
                               Content="跑分"
                               Click="ShowMemoryBenchmark_Click" />
                </StackPanel>

                <TextBox Width="220"
                         Height="34"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Text="查找"
                         Foreground="{StaticResource HwScopeMutedTextBrush}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView x:Name="RootNavigation"
                               Grid.Column="0"
                               PaneDisplayMode="LeftFluent"
                               IsPaneOpen="True"
                               OpenPaneLength="236"
                               CompactPaneLength="48"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="False"
                               IsPaneVisible="True"
                               SelectionChanged="RootNavigation_SelectionChanged">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem x:Name="SummaryNavigationItem"
                                           Content="硬件概览"
                                           Tag="summary"
                                           IsActive="True"
                                           Icon="{ui:SymbolIcon Home24}" />
                    <ui:NavigationViewItem Content="硬件"
                                           IsExpanded="True"
                                           Icon="{ui:SymbolIcon DeveloperBoard20}">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem Content="中央处理器 (CPU)"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon DeveloperBoard20}" />
                            <ui:NavigationViewItem Content="内存"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon Database24}" />
                            <ui:NavigationViewItem Content="显示设备"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon Desktop20}" />
                            <ui:NavigationViewItem Content="存储设备"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon HardDrive20}" />
                            <ui:NavigationViewItem Content="网络设备"
                                                   Tag="summary"
                                                   Icon="{ui:SymbolIcon WifiSettings20}" />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem Content="性能测试"
                                           IsExpanded="True"
                                           Icon="{ui:SymbolIcon TopSpeed20}">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem Content="内存跑分"
                                                   Tag="memory-benchmark"
                                                   Icon="{ui:SymbolIcon Gauge32}" />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>
            </ui:NavigationView>

            <Grid Grid.Column="1" Margin="0" Background="{DynamicResource ApplicationBackgroundBrush}">
                <Grid x:Name="SummaryPage" Margin="18" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="硬件概览"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="GeneratedAtText"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource HwScopeMutedTextBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <ui:Button x:Name="RefreshButton"
                                       Width="88"
                                       Height="34"
                                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                                       Content="刷新"
                                       Click="RefreshButton_Click" />
                            <ui:Button x:Name="CopyButton"
                                       Width="88"
                                       Height="34"
                                       Margin="8,0,0,0"
                                       Icon="{ui:SymbolIcon Copy24}"
                                       Content="复制"
                                       Click="CopyButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="#FFFFFFFF"
                            BorderBrush="{StaticResource HwScopeLineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18,4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HardwareSummaryList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:HardwareSummaryItem}">
                                        <Border Style="{StaticResource HardwareRowStyle}">
                                            <Grid MinHeight="48">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="116" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Label}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="#4B5563" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="4"
                   Background="{StaticResource HwScopePanelBrush}"
                   BorderBrush="{StaticResource HwScopeLineBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="FooterStatusText" Text="准备就绪" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
