<Window x:Class="HwScope.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HwScope.App"
        mc:Ignorable="d"
        Title="HwScope"
        MinHeight="560"
        MinWidth="860"
        Height="640"
        Width="980"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9DEE7" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="BorderBrush" Value="#C9D2DF" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#202939" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="HardwareRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E2E7EF" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="HwScope"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="硬件检测"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton"
                            Content="刷新"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="RefreshButton_Click" />
                    <Button x:Name="CopyButton"
                            Content="复制"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="CopyButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="检测项目"
                               Margin="16,16,16,10"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#344054" />
                    <ListBox SelectedIndex="0"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="14">
                        <ListBoxItem Content="硬件概览" Padding="16,10" />
                        <ListBoxItem Content="处理器" Padding="16,10" IsEnabled="False" />
                        <ListBoxItem Content="显卡" Padding="16,10" IsEnabled="False" />
                        <ListBoxItem Content="内存" Padding="16,10" IsEnabled="False" />
                        <ListBoxItem Content="硬盘" Padding="16,10" IsEnabled="False" />
                        <ListBoxItem Content="跑分" Padding="16,10" IsEnabled="False" />
                        <ListBoxItem Content="稳定性" Padding="16,10" IsEnabled="False" />
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="20,18,20,14">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="硬件概览"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock x:Name="GeneratedAtText"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="StatusBadge"
                                   DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"
                                   Background="#EEF4FF"
                                   Foreground="#3538CD"
                                   Padding="10,4"
                                   FontSize="12"
                                   Text="待检测" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="HardwareSummaryList"
                                      Margin="20,0,20,20"
                                      AlternationCount="100">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:HardwareSummaryItem}">
                                    <Border Style="{StaticResource HardwareRowStyle}">
                                        <Grid MinHeight="48">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="104" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#475467" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       Foreground="#101828"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="FooterStatusText"
                       Margin="24,10"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="准备就绪" />
        </Border>
    </Grid>
</Window>

